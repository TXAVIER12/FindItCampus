<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/deep_forest_green">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FindIt Campus"
                style="@style/TextTitleManifest" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOST &amp; FOUND MANIFEST"
                style="@style/TextSubtitleManifest" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/content_area_bg">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvDetailType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/type_pill_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="LOST"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvDetailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/status_open"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        tools:text="Status: Open" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_on_light"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginBottom="4dp"
                    tools:text="Blue Backpack" />

                <TextView
                    android:id="@+id/tvDetailCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="15sp"
                    android:layout_marginBottom="24dp"
                    tools:text="Category: Bag" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/cream_input"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="DESCRIPTION"
                            style="@style/SectionLabelManifest" />
                        <TextView
                            android:id="@+id/tvDetailDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            android:textColor="@color/text_on_light"
                            android:textSize="15sp"
                            android:lineSpacingExtra="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="LOCATION"
                            style="@style/SectionLabelManifest" />
                        <TextView
                            android:id="@+id/tvDetailLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            android:textColor="@color/text_on_light"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="DATE"
                            style="@style/SectionLabelManifest" />
                        <TextView
                            android:id="@+id/tvDetailDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            android:textColor="@color/text_on_light"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvHandInLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="HANDED IN / STORED AT"
                            style="@style/SectionLabelManifest" />
                        <TextView
                            android:id="@+id/tvDetailHandIn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            android:textColor="@color/text_on_light"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="CONTACT INFORMATION"
                            style="@style/SectionLabelManifest" />
                        <TextView
                            android:id="@+id/tvDetailContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_on_light"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACTIONS"
                    style="@style/SectionLabelManifest"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMarkClaimed"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:backgroundTint="@color/lost_red"
                        android:text="Claimed"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMarkReturned"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        android:backgroundTint="@color/found_teal"
                        android:text="Returned"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMarkResolved"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:backgroundTint="@color/primary_dark"
                        android:text="Resolved"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:text="Remove Report"
                    android:textColor="@color/lost_red"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="@color/lost_red"
                    app:iconGravity="textStart" />

                <View android:layout_width="match_parent" android:layout_height="60dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</LinearLayout>
