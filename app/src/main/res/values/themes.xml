<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FindItCampus" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/deep_forest_green</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_gold</item>
        <item name="android:windowBackground">@color/deep_forest_green</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundColor">@color/cream_surface</item>
        <item name="itemIconTint">@color/text_on_light</item>
        <item name="itemTextColor">@color/text_on_light</item>
    </style>

    <!-- Header Titles -->
    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="TextTitleManifest" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="TextSubtitleManifest" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Section Labels -->
    <style name="SectionLabel">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="SectionLabelManifest" parent="SectionLabel" />

    <!-- Inputs -->
    <style name="ManifestInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/cream_input</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <!-- Buttons -->
    <style name="ManifestButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
